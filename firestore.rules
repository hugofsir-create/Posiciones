rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // All collections (records, reports, pallets, pallet_reports, cepas, cepas_reports)
    // follow a similar pattern:
    // - uid: string (required, owner)
    // - created_at: timestamp/string (optional)
    // - other fields specific to the entity
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validators
    function isValidRecord(data) {
      return data.uid == request.auth.uid &&
             data.date is string &&
             data.kilos is number;
    }

    function isValidReport(data) {
      return data.uid == request.auth.uid &&
             data.month is string &&
             data.period is string;
    }

    function isValidPallet(data) {
      return data.uid == request.auth.uid &&
             data.date is string &&
             data.positions is number;
    }

    function isValidCepas(data) {
      return data.uid == request.auth.uid &&
             data.date is string &&
             data.positions is number;
    }

    // Rules
    match /records/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidRecord(request.resource.data);
      allow update: if isDocOwner() && isValidRecord(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /reports/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isDocOwner() && isValidReport(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /pallets/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPallet(request.resource.data);
      allow update: if isDocOwner() && isValidPallet(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /pallet_reports/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == request.auth.uid && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /cepas/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCepas(request.resource.data);
      allow update: if isDocOwner() && isValidCepas(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /cepas_reports/{id} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == request.auth.uid && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
